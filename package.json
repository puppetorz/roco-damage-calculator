{
  "name": "roco-damage-calculator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package:local": "npm run build && node scripts/packageLocal.mjs",
    "import:data": "node scripts/importWikiData.mjs",
    "import:pvp-lineups": "node scripts/importPvpLineupsFromBwiki.mjs",
    "import:spirits": "node scripts/importSpiritStatsFromXlsx.mjs",
    "import:spirits:bwiki": "node scripts/importSpiritsFromBwiki.mjs",
    "import:skills": "node scripts/importSkillsFromBwiki.mjs",
    "analyze:pvp-teams": "npx --yes tsx scripts/analyzePvpTeams.mts",
    "simulate:pvp-battle": "npx --yes tsx scripts/simulatePvpBattle.mts",
    "verify:pvp-rules": "npx --yes tsx scripts/verifyPvpBattleRules.mts",
    "validate:data": "node scripts/validateData.mjs"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
